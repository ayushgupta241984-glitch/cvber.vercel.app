# ===================================================
# CVBER Free API - Environment Configuration
# Copy to .env and fill in your values
# ===================================================

# ==================== FRONTEND (Vercel) ====================
# These must be set in Vercel dashboard (Settings > Environment Variables)
# NEXT_PUBLIC_ variables are exposed to the browser

# Backend URL - MUST be set on Vercel for production!
# Without this, frontend defaults to http://localhost:8000
# Example: https://cvber-backend.onrender.com
NEXT_PUBLIC_BACKEND_URL=

# Supabase - for client-side auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ==================== BACKEND (Render) ====================
# These are set on the backend server (Render dashboard)

# Supabase Admin (service_role bypasses RLS - keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend config
BACKEND_URL=http://localhost:8000
JWT_SECRET=your-jwt-secret-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Model Configuration
# At least one AI provider key is required for AI features
# Priority: Groq > Google AI > Vertex AI

# Groq AI (Recommended - free tier available)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview

# Google AI Studio (Fallback)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash

# Vertex AI (Enterprise - requires service account JSON)
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-flash-002

# Cloud KMS
KMS_KEYRING=cvber-free-keyring
KMS_KEY=c2pa-signing-key
KMS_LOCATION=us-central1

# C2PA Service
C2PA_SERVICE_URL=http://localhost:3001
C2PA_CERT=certs/certificate.pem
C2PA_PRIVATE_KEY=certs/private.key
C2PA_KEY_VERSION=v1

# CORS - Comma-separated list of allowed frontend origins
# Vercel preview domains (*.vercel.app) are auto-allowed via regex
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://cvber.vercel.app

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
