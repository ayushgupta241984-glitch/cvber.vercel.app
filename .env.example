# ===================================================
# CVBER Free API - Environment Configuration
# Copy to .env and fill in your values
# ===================================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend API
BACKEND_URL=http://localhost:8000
JWT_SECRET=your-jwt-secret-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Model Configuration
# At least one AI provider key is required for AI features
# Priority: Groq > Google AI > Vertex AI

# Groq AI (Recommended - free tier available)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google AI Studio (Fallback)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash

# Vertex AI (Enterprise)
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-flash-002

# Cloud KMS
KMS_KEYRING=cvber-free-keyring
KMS_KEY=c2pa-signing-key
KMS_LOCATION=us-central1

# C2PA Service
C2PA_SERVICE_URL=http://localhost:3001
C2PA_CERT=certs/certificate.pem
C2PA_PRIVATE_KEY=certs/private.key
C2PA_KEY_VERSION=v1

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://cvber.vercel.app

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
